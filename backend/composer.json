{
    "name": "instagramtech/backend",
    "description": "Vee - Social Media API",
    "keywords": ["laravel", "framework", "social-media"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "intervention/image": "^3.3",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -d upload_max_filesize=2048M -d post_max_size=2050M -d memory_limit=1024M -d max_execution_time=0 -d max_input_time=-1 artisan serve --host=0.0.0.0 --port=${PORT:-8080}",
        "serve:api-large": "php -d upload_max_filesize=2048M -d post_max_size=2050M -d memory_limit=1024M -d max_execution_time=0 -d max_input_time=-1 artisan serve --host=127.0.0.1 --port=8002",
        "serve:large": "php -d upload_max_filesize=2048M -d post_max_size=2050M -d memory_limit=1024M -d max_execution_time=0 -d max_input_time=-1 artisan serve --host=0.0.0.0 --port=8003",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2.30"
        },
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
